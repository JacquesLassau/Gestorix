@using GestorixDLL.Infrastructure
@model GestorixDLL.DML.PedidoViewModelDML
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<hr />
<p class="fs-2 fw-lighter bg-light">Relatório de Vendas</p>
<hr />

<div class="row mb-3">
    <div class="col-md-3">
        <label for="dataInicio" class="form-label">Data Início:</label>
        <input type="date" id="dataInicio" class="form-control" />
    </div>
    <div class="col-md-3">
        <label for="dataFim" class="form-label">Data Fim:</label>
        <input type="date" id="dataFim" class="form-control" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button id="buscarRelatorio" class="btn btn-primary w-100">
            <i class="fa fa-search"></i> Buscar
        </button>
    </div>
</div>

<div id="relatorio-content" style="display:none;">
        
    <h4>Lista de Pedidos e Totais Sintéticos</h4>
    <div class="border rounded p-3 mb-4">
        <table id="tabela-sintetica" class="table table-striped table-bordered mb-3"></table>
        <table id="tabela-total-sintetica" class="table table-sm table-bordered table-hover w-50"></table>
        <button class="btn btn-outline-secondary mt-2" onclick="imprimirTabelaSintetica()">
            <i class="fa fa-print"></i> Impressão - Relatório Sintético
        </button>
    </div>
    <hr />
        
    <h4>Lista Analítica de Produtos e Serviços dos Pedidos</h4>
    <div class="border rounded p-3 mb-4">
        <table id="tabela-analitica" class="table table-striped table-bordered mb-3"></table>
        <table id="tabela-total-analitica" class="table table-sm table-bordered table-hover w-50"></table>
        <button class="btn btn-outline-secondary mt-2" onclick="imprimirTabelaAnalitica()">
            <i class="fa fa-print"></i> Impressão - Relatório Analítico
        </button>
    </div>
    <hr />

    <h4>Produtos e Serviços Mais Vendidos</h4>
    <table id="tabela-mais-vendidos" class="table table-striped table-bordered"></table>
    <hr />

    <h4>Produtos e Serviços com Maior Lucro</h4>
    <table id="tabela-maior-lucro" class="table table-striped table-bordered"></table>
    <hr />

    <h4>Produtos e Serviços com Menor Lucro</h4>
    <table id="tabela-menor-lucro" class="table table-striped table-bordered"></table>
    <hr />

    <div id="resumo-geral" class="mt-4"></div>

</div>

@Scripts.Render("~/Scripts/Relatorio/BuscarRelatorio.js")