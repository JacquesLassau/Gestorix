﻿@model Gestorix.Models.Usuario
@{
    ViewBag.Title = "Login";
    string local = Url.Action("PasswordRecouver", "Authentication");
    string contexto = Url.Action("Login", "Authentication");
}

<div class="bg-body">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <hr />
                <p class="fs-2 fw-lighter bg-light">Recuperar Senha</p>
                <hr />
                @using (Html.BeginForm("PasswordRecouver", "Authentication", FormMethod.Post))
                {
                    <div class="form-group">
                        @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-12">
                            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control required-form" } })
                            @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                        </div>
                    </div>                    
                    <div class="form-group">                        
                        <button type="submit" class="btn btn-primary form-group"><i class="fa fa-paper-plane"></i> Gerar Link de Acesso.</button>
                    </div>
                    @Html.AntiForgeryToken()
                }                
            </div>
        </div>
    </div>
</div>


@section Scripts {@Scripts.Render("~/bundles/jqueryval")}