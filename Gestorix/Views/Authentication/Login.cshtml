@using GestorixDLL.Infrastructure;
@model Gestorix.Models.Usuario
@{
    Layout = null;
    ViewBag.Title = "Login";
    string local = Url.Action("Login", "Authentication");
}
<style>
    .main-head {
        height: 150px;
        background: #FFF;
    }

    .sidenav {
        height: 100%;
        background-color: #010101;
        overflow-x: hidden;
        padding-top: 20px;
    }


    .main {
        padding: 0px 10px;
    }

    @@media screen and (max-height: 450px) {
        .sidenav {
            padding-top: 15px;
        }
    }

    @@media screen and (max-width: 450px) {
        .login-form {
            margin-top: 10%;
        }

        .register-form {
            margin-top: 10%;
        }
    }

    @@media screen and (min-width: 768px) {
        .main {
            margin-left: 40%;
        }

        .sidenav {
            width: 40%;
            position: fixed;
            z-index: 1;
            top: 0;
            left: 0;
        }

        .login-form {
            margin-top: 53%;
        }

        .register-form {
            margin-top: 20%;
        }
    }


    .login-main-text {
        margin-top: 20%;
        padding: 60px;
        color: #fff;
    }

        .login-main-text h2 {
            font-weight: 300;
        }

    .btn-black {
        background-color: #010101 !important;
        color: #fff;
    }

        .btn-black:hover {
            background-color: #2c2c2c !important;
            color: #fff;
        }

    .jconfirm.jconfirm-white .jconfirm-box .jconfirm-buttons button, .jconfirm.jconfirm-light .jconfirm-box .jconfirm-buttons button {
        background-color: #2c2c2c;
        color: #fff !important;
        border: 1px solid #2c2c2c !important;
        text-transform: none !important;
        font-weight: normal !important;
    }

        .jconfirm.jconfirm-white .jconfirm-box .jconfirm-buttons button, .jconfirm.jconfirm-light .jconfirm-box .jconfirm-buttons button:hover {
            background-color: #fff !important;
            color: #2c2c2c !important;
            border: 1px solid #2c2c2c !important;
            text-transform: none !important;
            font-weight: normal !important;
        }
</style>
<link rel="icon" type="image/png" href="~/Images/logo-header.png">
<meta http-equiv="content-type" content="text/html; charset=UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
<title>Gestorix</title>
<meta name="description" content="GESTORIX">
<meta name=" author" content="Jacques de Lassau">
<meta http-equiv="content-language" content="pt-br">
<meta name="robots" content="index,nofollow">
<meta name="rating" content="general">
<div class="sidenav">
    <div class="login-main-text">
        <img src="~/Images/banner.jpg" />
    </div>
</div>
<div class="main">
    <div class="col-md-6 col-sm-12">
        <div class="login-form">
            @using (Html.BeginForm("Login", "Authentication", FormMethod.Post))
            {
                <div class="form-group">
                    <label>E-mail:</label>
                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", placeholder = "E-mail", required = "required" } })
                </div>
                <div class="form-group">
                    <label>Senha:</label>
                    @Html.EditorFor(model => model.Senha, new { htmlAttributes = new { @class = "form-control", placeholder = "Senha", required = "required", minlength = "3" } })
                </div>
                <button type="submit" class="btn btn-black" style="width:100%;">Acessar</button> 
                <hr/>
                <a class="mt-1 is-block is-fullwidth" href="@Url.Action("PasswordRecouver", "Authentication")" style="color: #010101; text-decoration: none;" onMouseOver="this.style.color = '#2e2e2e'" onMouseOut="this.style.color='#010101'">Esqueceu a senha? <br/><b>Clique aqui para recuperar.</b></a>
                @Html.AntiForgeryToken()
            }
        </div>
    </div>
</div>

<link href="//maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css" rel="stylesheet" id="bootstrap-css">
<script src="//maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
<script src="//code.jquery.com/jquery-1.11.1.min.js"></script>

@if (TempData != null && TempData.ContainsKey(ConstantesAlerta.MENSAGEM_TEMP_DATA_TITULO))
{
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.2/jquery-confirm.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.2/jquery-confirm.min.js"></script>

    <script type="text/javascript">
                $(document).ready(function () {
                    $.confirm({
                        title: '<p style="text-align:center;padding:16px;width:100%;">@Html.Raw(HttpUtility.JavaScriptStringEncode(TempData[ConstantesAlerta.MENSAGEM_TEMP_DATA_TITULO].ToString()))</p>',
                        content: '<p style="text-align:center;">@Html.Raw(HttpUtility.JavaScriptStringEncode(TempData[ConstantesAlerta.MENSAGEM_TEMP_DATA_DESCRICAO].ToString()))</p>',
                        type: 'warning',
                        typeAnimated: true,
                        containerFluid: true,
                        columnClass: 'col-lg-6 col-md-6 col-sm-6 col-xs-8',
                        animationBounce: 2,
                        buttons: {
                            tryAgain: {
                                text: 'Novamente',
                                btnClass: 'btn-outline-dark',
                                action: function () {
                                }
                            },
                            close: {
                                text: 'Sair',
                                btnClass: 'btn-outline-dark',
                                action: function () {
                                    window.location.href = '@local';
                                }
                            }
                        }
                    });
                });
    </script>
}