@using DispelDLL.Infrastructure
@model DispelDLL.DML.PedidoViewModelDML
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    string popOrcamentoPedido = "~/Views/Pedido/_OrcamentoPedido.cshtml";
    string mdListaProdutos = "~/Views/Produto/_ModalListaProdutoUI.cshtml";

}
<style>

    form {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

        form input {
            padding: 5px;
            border-radius: 0.25rem;
        }

        form button {
            padding: 6px 12px;
        }

        form select {
            padding: 5px;
            width: 160px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
    }

    table, th, td {
        border: 1px solid #ccc;
    }

    th, td {
        padding: 8px;
        text-align: center;
    }

    th {
        background-color: #f2f2f2;
    }

    .remove-btn {
        background-color: #e95d4f;
        color: white;
        border: none;
        padding: 5px 8px;
        cursor: pointer;
        border-radius: 4px;
    }

    .edit-btn {
        background-color: #0d6efd;
        color: white;
        border: none;
        padding: 5px 8px;
        cursor: pointer;
        border-radius: 4px;
    }

    .total {
        font-weight: bold;
        font-size: 18px;
        margin-top: 10px;
    }

    #finalizar-pedido {
        padding: 10px 20px;
        background-color: #198754;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        float: right;
        margin-left: 1%;
    }

    #imprimir-pedido {
        padding: 10px 20px;
        background-color: #198754;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        float: right;
        margin-left: 1%;
    }

    #desfazer-pedido {
        padding: 10px 20px;
        border: 1px solid #0d6efd;
        background-color: #fff;
        color: #0d6efd;
        border-radius: 5px;
        cursor: pointer;
        float: right;
        margin-left: 1%;
    }

    .select-pedido {
        padding-right: 24px; /* afasta o texto da seta */
        background: white;
        border: 1px solid #ccc;
        border-radius: 4px;
        appearance: none; /* remove estilo padrão */
        -webkit-appearance: none; /* Safari/Chrome */
        -moz-appearance: none; /* Firefox */
        background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg fill='gray' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M7 10l5 5 5-5z'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 6px center; /* seta mais à esquerda */
        background-size: 16px 16px;
        cursor: pointer;
    }

    .table-wrapper {
        overflow-x: auto; /* para permitir rolagem horizontal em celulares */
        width: 100%;
    }

    .table > :not(:last-child) > :last-child {
        font-size: 12px !important;
    }
</style>

<hr />
<p class="fs-2 fw-lighter bg-light">Orçamento nº <span id="nrOrcamento">@(new HtmlString((Model.Pedido.Count + 1).ToString()))</span></p>
<hr />

<div class="row space-form p-1">
    <div class="col-md-3 col-xs-12"></div>
    <div class="col-md-3 col-xs-12"></div>
    <div class="col-md-3 col-xs-12"></div>
    <div class="col-md-3 col-xs-12">
        <a value="" name="btnReferenciaProduto" class="btn btn-large btn-primary form-group btnPesquisar" data-bs-toggle="modal" data-bs-target="#Produtos"
           onclick='$("#tipo").val("Produto"); $("#referencia").val(""); $("#descricao").val(""); $("#custo").val(""); $("#preco").val("");$("#quantiidade").val("")'>
            <i class="fa fa-list"></i>
            Lista de Produtos e Serviços
        </a>
    </div>
    @{ Html.RenderPartial(mdListaProdutos);}
</div>
<div class="row">
    <div class="col-md-12">
        <i class="fa fa-square legenda-campos-obrigatorios"></i> Preencha os campos para adicionar o produto/serviço ao pedido.
    </div>
</div>
<form id="pedido-form" class="pedido-form-horizontal">
    <div class="field-wrap">
        <label for="Tipo">Tipo:</label>
        <select class="select-pedido" id="Tipo" name="Tipo" style="background-color:lightyellow;">
            <option value="Produto">Produto</option>
            <option value="Servico">Servico</option>
        </select>
    </div>
    <div class="field-wrap" style="width:12%;">
        <label for="ReferenciaProduto">Referência:</label>
        <div class="input-group">
            <input type="text" id="ReferenciaProduto" class="form-control required-form"
                   placeholder="Referência" required
                   oninvalid="this.setCustomValidity('Informe a Referência')"
                   oninput="this.setCustomValidity('')">

            <div class="input-group-append">
                <a class="btn btn-primary" onclick="BuscarItem()" style="padding:7px;">
                    <i class="fa fa-search"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="field-wrap" style="width:25%;">
        <label for="Descricao">Descrição:</label>
        <input type="text" id="Descricao" class="required-form" placeholder="Descrição" required>
    </div>
    <div class="field-wrap" style="width:12%;">
        <label for="Custo">Custo R$:</label>
        <input type="text" step="0.01" id="Custo" class="required-form" placeholder="Custo R$" required
               oninvalid="this.setCustomValidity('Informe o Custo R$')"
               oninput="this.setCustomValidity('')">
    </div>
    <div class="field-wrap" style="width:12%;">
        <label for="Preco">Preço R$:</label>
        <input type="text" step="0.01" id="Preco" class="required-form" placeholder="Preço R$" required
               oninvalid="this.setCustomValidity('Informe o Preço R$')"
               oninput="this.setCustomValidity('')">
    </div>
    <div class="field-wrap" style="width:12%;">
        <label for="Quantidade">Quantidade:</label>
        <input type="number" id="Quantidade" class="required-form" placeholder="Quantidade" required
               oninvalid="this.setCustomValidity('Informe a quantidade de Produtos/Serviços')"
               oninput="this.setCustomValidity('')">
    </div>
    <div class="field-wrap">
        <label>&nbsp;</label>
        <button type="submit" id="botao-add" class="btn btn-success">
            <i class="fa fa-plus-circle"></i> <span>Adicionar</span>
        </button>
    </div>
</form>
<hr />
<div class="row">
    <div class="col-md-12">
        <br />
        <i class="fa fa-square legenda-campos-leitura"></i> Produtos/serviços adicionados ao pedido.
    </div>
</div>
<div class="table-wrapper">
    <table id="pedido-table">
        <thead>
            <tr>
                <th>Tipo</th>
                <th>Referência</th>
                <th>Descrição</th>
                <th style="background-color:#d9d9d9">Custo R$</th>
                <th style="background-color:#d9d9d9">Preço R$</th>
                <th style="background-color: #c1c1c1">Lucro Total R$</th>
                <th style="background-color: #c1c1c1">Preço Total R$</th>
                <th>Quantidade</th>
                <th colspan="2">Ações</th>
            </tr>
        </thead>
        <tbody>
            <!-- Itens inseridos aparecerão aqui -->
        </tbody>
    </table>
    <div id="alerta-edicao" style="color: #b02a37; font-size: 1.2rem; margin-top: 5px; display: none;">
        Atenção, você está atualizando/alterando uma venda que já foi fechada.
    </div>
</div>
<br />
<div class="total" id="total-custo">Custo Total: R$ 0.00</div>
<div class="total" id="total-pedido">Preço Total: R$ 0.00</div>
<div class="total" id="total-liquido">Lucro Total: R$ 0.00</div>
<hr />

<div class="row">
    <div class="col-md-6">
    </div>
    <div class="col-md-6">
        <button id="finalizar-pedido"><i class="fa fa-check"></i> Fechar Venda</button>
        <button id="imprimir-pedido"><i class="fa fa-file-pdf-o"></i> Pré Venda</button>
        <a onclick="window.location.href = location.href" id="desfazer-pedido"><i class="fa fa-refresh"></i> Desfazer</a>
    </div>
</div>

@{ Html.RenderPartial(popOrcamentoPedido); }

<br />
<div class="monitor">
    <hr />
    <p class="fs-2 fw-lighter bg-light">Lista de Pedidos</p>
    <hr />
    <div class="row legenda-monitor">
        <div class="col-md-12">
            <i class="fa fa-square" style="color:#def0de;"></i> Finalizado &nbsp;
            <i class="fa fa-square" style="color:#f7dcdb;"></i> Excluído &nbsp;
        </div>
    </div>
    <table id="tabPedidos" class="table-wrapper table table-striped lista-propriedades lista-propriedades-monitor">
        <thead>
            <tr>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Nº Pedido</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Data e Hora</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Descrição dos Itens</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Custo R$</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Preço R$</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Recebimento R$</th>
                <th class="orderBy-table"><i class="fa fa fa-sort"></i> Ação</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Pedido != null && Model.Pedido.Count > 0)
            {
                foreach (var item in Model.Pedido)
                {
                    if (item.Situacao == Constantes.ATIVO)
                    {
                        <tr class="finalizado">
                            <td class="finalizados align-middle">@item.IdPedido</td>
                            <td class="finalizados align-middle">@Utilidades.ConverterParaHrBrasilia(item.DataHoraPedidoFinalizado)</td>
                            <td class="finalizados align-middle">@(new HtmlString(item.DescricaoItens))</td>
                            <td class="finalizados align-middle">@item.TotalCusto</td>
                            <td class="finalizados align-middle">@item.TotalPedido</td>
                            <td class="finalizados align-middle">@item.TotalLucro</td>
                            <td class="finalizados align-middle">
                                <a data-id="@item.IdPedido" class="btn btn-sm btn-outline-success" onclick="EditarPedido(@item.IdPedido)"><i class="fa fa-edit"></i> Editar </a>
                                <a data-id="@item.IdPedido" class="btn btn-sm btn-outline-danger" onclick="RemoverPedido(@item.IdPedido)"><i class="fa fa-remove"></i> Remover </a>
                            </td>
                        </tr>
                    }
                    else if (item.Situacao == Constantes.INATIVO)
                    {
                        <tr class="excluido">
                            <td class="excluidos align-middle">@item.IdPedido</td>
                            <td class="excluidos align-middle">@Utilidades.ConverterParaHrBrasilia(item.DataHoraPedidoExcluido)</td>
                            <td class="excluidos align-middle">@(new HtmlString(item.DescricaoItens))</td>
                            <td class="excluidos align-middle">@item.TotalCusto</td>
                            <td class="excluidos align-middle">@item.TotalPedido</td>
                            <td class="excluidos align-middle">@item.TotalLucro</td>
                            <td class="excluidos align-middle">
                                <a class="btn btn-sm btn-default disabled" readonly="readonly"><i class="fa fa-edit"></i> Editar </a>
                                <a class="btn btn-sm btn-default disabled" readonly="readonly"><i class="fa fa-remove"></i> Remover </a>
                            </td>
                        </tr>
                    }

                }
            }
        </tbody>
    </table>
</div>

@Scripts.Render("~/Scripts/Pedido/BuscarPedido.js")
@Scripts.Render("~/Scripts/Pedido/CadastrarPedido.js")
@Scripts.Render("~/Scripts/Pedido/EditarPedido.js")
@Scripts.Render("~/Scripts/Pedido/ExcluirPedido.js")