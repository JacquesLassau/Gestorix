<div class="modal fade" id="removeModal" tabindex="-1" aria-labelledby="removeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="removeModalLabel">Confirma Remoção do Estoque?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Insira a quantidade de produtos que deseja remover ao estoque:
                <div class="d-flex align-items-center">
                    <div class="input-group numberControlProducts">
                        <input type="text" class="form-control" id="RmvQuantidade" maxlength="6">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="AtualizarProdutoNoEstoque('rmv')"><i class="fa fa-remove"></i> Remover</button>
            </div>
        </div>
    </div>
</div>
